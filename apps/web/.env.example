# Public URL of the deployed PocketBase instance.
# Local dev can leave this empty; the Vite dev server proxies /hcgi/platform.
VITE_POCKETBASE_URL=https://your-app.pockethost.io

# Public URL of the Express API (this repo's apps/api, deployed separately).
# Local dev can leave this empty; the Vite dev server proxies /hcgi/api.
VITE_API_URL=https://your-api.vercel.app
