# Supabase project URL and anon (publishable) key.
# Dashboard → Project Settings → API.
# The anon key is safe to ship to the browser; RLS policies enforce access control.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Public URL of the Express API (apps/api, deployed separately).
# Leave empty for local dev — the Vite dev server can proxy /hcgi/api if needed.
VITE_API_URL=https://your-api.vercel.app
