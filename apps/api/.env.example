# API server port (ignored on Vercel)
PORT=3001

# Comma-separated list of allowed origins. Leave empty for "*" without credentials.
CORS_ORIGIN=http://localhost:3000

# PocketBase connection
POCKETBASE_URL=http://127.0.0.1:8090
PB_SUPERUSER_EMAIL=admin@example.com
PB_SUPERUSER_PASSWORD=change-me

# Per-API-key requests per hour
API_KEY_RATE_LIMIT=100
