# API server port (ignored on Vercel)
PORT=3001

# Comma-separated list of allowed origins. Leave empty for "*" without credentials.
CORS_ORIGIN=http://localhost:3000

# Supabase — get these from Dashboard → Project Settings → API.
# SUPABASE_SERVICE_ROLE_KEY has full DB access. NEVER expose it to the browser
# and NEVER commit a real value; it lives only in server env.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Per-API-key requests per hour
API_KEY_RATE_LIMIT=100

# Cloudflare R2 — creator uploads live here, not in Supabase Storage.
# Dashboard → R2 → Manage R2 API Tokens → "Object Read & Write".
# R2_ACCOUNT_ID: R2 dashboard → top-right account id.
# R2_BUCKET: the bucket name you created (e.g. "onlycats-content").
# R2_PUBLIC_URL: either the bucket's r2.dev public URL (Settings → Public access)
#   or a custom domain you've attached (e.g. https://cdn.yourdomain.com).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=onlycats-content
R2_PUBLIC_URL=https://pub-XXXX.r2.dev
