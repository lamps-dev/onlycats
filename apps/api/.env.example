# API server port (ignored on Vercel)
PORT=3001

# Comma-separated list of allowed origins. Leave empty for "*" without credentials.
CORS_ORIGIN=http://localhost:3000

# Supabase — get these from Dashboard → Project Settings → API.
# SUPABASE_SERVICE_ROLE_KEY has full DB access. NEVER expose it to the browser
# and NEVER commit a real value; it lives only in server env.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Per-API-key requests per hour
API_KEY_RATE_LIMIT=100
